# ─────────────────────────────────────────────────────────────────────────────
# LLM provider — pick ONE of the two blocks below.
# Server auto-detects: if AI_GATEWAY_API_KEY is set it routes through Vercel
# AI Gateway, otherwise it falls back to direct DashScope.
# ─────────────────────────────────────────────────────────────────────────────

# ① Vercel AI Gateway (used in production — SuperAI hackathon submission)
#    Get a key at https://vercel.com/d/ai-gateway → API Keys
AI_GATEWAY_API_KEY=vck_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional — pin to a specific model on the Gateway (defaults shown).
# Alternatives: alibaba/qwen3.7-max, alibaba/qwen3-vl-235b-a22b-instruct
# GATEWAY_TEXT_MODEL=alibaba/qwen3-max
# GATEWAY_VISION_MODEL=alibaba/qwen3-vl-instruct

# ② DashScope direct (local-dev fallback)
QWEN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

PORT=3000
